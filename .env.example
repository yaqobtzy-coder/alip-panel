# === Firebase ===
# Full service-account JSON as ONE LINE string. Get it from:
# Firebase Console > Project settings > Service accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# === Session ===
# Any long random string (e.g. `openssl rand -hex 32`)
SESSION_SECRET=change-this-to-a-long-random-string

# === Telegram bot ===
# Get a token from @BotFather. Never reuse a token that's been pasted/shared
# anywhere public — rotate it first.
TELEGRAM_BOT_TOKEN=123456:your-bot-token
TELEGRAM_OWNER_CHAT_ID=your-telegram-chat-id

# === ALIP-DB ===
ALIP_DB_BASE_URL=http://alipai-db.clutch.web.id
ALIP_DB_API_KEY=your-alip-db-api-key

# === Pakasir (QRIS payment gateway — gateway "manual": ACC pembayaran
# tetap manual lewat Telegram, bisa masuk antrian) ===
# Dashboard: https://pakasir.com
PAKASIR_PROJECT=your-pakasir-project-slug
PAKASIR_API_KEY=your-pakasir-api-key

# === RikyShopReal (QRIS v2 payment gateway — gateway "auto": full
# otomatis, status dicek langsung ke gateway, tanpa upload bukti/ACC
# manual) ===
RIKYSHOP_BASE_URL=https://payment.rikyshopreal.cyou
RIKYSHOP_API_KEY=your-rikyshopreal-api-key

# === Tools Zone: Canvas API (certificates, filters, generators) ===
TOOLS_ZONE_API_KEY=your-tools-zone-canvas-api-key

# === Sewa GC (addsewagc) — koneksi langsung ke endpoint di proses bot ===
# Sesuaikan host:port dengan tempat bot Hutao-AI kamu jalan (SEWAGC_API_PORT
# di bot, default 7071). Harus sama persis dengan SEWAGC_API_KEY di bot.
SEWAGC_API_BASE_URL=http://localhost:7071
SEWAGC_API_KEY=your-sewagc-api-key

# === Tools Zone: AI chat ===
AI_API_URL=https://your-ai-provider.example.com/v1/chat/completions
AI_API_KEY=your-ai-provider-api-key

# === Rayy Store (admin web login) ===
RAYY_ADMIN_USERNAME=admin
RAYY_ADMIN_PASSWORD=change-this-admin-password
